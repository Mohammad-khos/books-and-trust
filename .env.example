#environment
ENVIRONMENT=development

#loki
LOKI_HOST_PORT=3100

#prometheus
PROMETHEUS_HOST_PORT=9999

#swager
SWAGGER_JSON=/shared/swagger.json
SWAGGER_UI_HOST_PORT=8082

#grafana
GRAFANA_VERSION=latest
GRAFANA_HOST_PORT=3000
GF_SECURITY_ADMIN_PASSWORD=admin

#versions
POSTGRES_VERSION=16.3
MIGRATE_VERSION=4.17.0
PGADMIN_VERSION=8.7
LOKI_VERSION=3.0.0
PROMETHEUS_VERSION=latest

#otel collector
OTEL_COLLECTOR_VERSION=0.102.0
OTLP_GRPC_HOST_PORT=4319
OTLP_HTTP_HOST_PORT=4320
OTLP_FLUENTD_HOST_PORT=24224

#jaeger
JAEGER_VERSION=1.57
JAEGER_ENDPOINT=jaeger:4317
COLLECTOR_OTLP_ENABLED=true

#gateway
APIGATEWAY_ADDR=:8081
APIGATEWAY_HOST_PORT=8081
APIGATEWAY_GOMEMLIMIT=450000000
APIGATEWAY_GOGC=100
FLUENTD_PORT=24224

#loan service
LOAN_SERVICE_ADDR=:9092
LOAN_SERVICE_HOST_PORT=9092
LOANS_DB_URI=host=loans_postgres_db user=loans_admin password=secretpass dbname=loans port=5432 sslmode=disable
LOANS_DB_MAX_OPEN_CONNS=30
LOANS_DB_MAX_IDLE_CONNS=30
LOANS_DB_MAX_IDLE_TIME=15m
LOAN_SERVICE_GOMEMLIMIT=450000000
LOAN_SERVICE_GOGC=100

#loans database
LOAN_DB_NAME=loans
LOAN_DB_USER=loans_admin
LOAN_DB_PASSWORD=secretpass

#user service
USER_SERVICE_HOST_PORT=9091
USER_SERVICE_ADDR=:9091
USER_SERVICE_GOMEMLIMIT=450000000
USER_SERVICE_GOGC=100
USERS_DB_URI=host=user_postgres_db user=users_admin password=secretpass dbname=users port=5432 sslmode=disable
USERS_DB_MAX_OPEN_CONNS=30
USERS_DB_MAX_IDLE_CONNS=30
USERS_DB_MAX_IDLE_TIME=15m
JWT_SECRET=t9pLwohkk3VvAV6ADtOBwDUsZjpvBj1P
JWT_AUD=books-and-trust

#users database
USER_DB_NAME=users
USER_DB_USER=users_admin
USER_DB_PASSWORD=secretpass

#users database pgadmin
PGADMIN_USERS_DEFAULT_EMAIL=your_admin_email@example.com
PGADMIN_USERS_DEFAULT_PASSWORD=your_admin_password
PGADMIN_USERS_LISTEN_PORT=80

#loans database pgadmin
PGADMIN_LOANS_DEFAULT_EMAIL=your_admin_email@example.com
PGADMIN_LOANS_DEFAULT_PASSWORD=your_admin_password
PGADMIN_LOANS_LISTEN_PORT=80

#redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=secretpass
REDIS_VERSION=7.2
REDIS_TAG=alpine
REDIS_DB=0

